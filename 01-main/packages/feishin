DEFVER=1
ARCHS_SUPPORTED="amd64 arm64"
get_github_releases "jeffvli/feishin" latest
if [ "${ACTION}" != "prettylist" ]; then
    URL=$(grep "browser_download_url.*${HOST_ARCH}\.deb\"" "${CACHE_FILE}" | cut -d '"' -f 4)
