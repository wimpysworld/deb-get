DEFVER=1
ARCHS_SUPPORTED="amd64 arm64 armhf"
get_github_releases "junegunn/fzf" "latest"
if [ "${ACTION}" != prettylist ]; then
    URL="$(grep -m 1 "browser_download_url.*${HOST_ARCH/hf/v7}\.deb\"" "${CACHE_FILE}" | cut -d'"' -f4)"
    VERSION_PUBLISHED=$(cut -d'/' -f8 <<< "${URL}" | tr -d v)
fi
PRETTY_NAME="Fzf"
WEBSITE="https://junegunn.github.io/fzf/"
SUMMARY="🌸 A command-line fuzzy finder"
