DEFVER=1
ARCHS_SUPPORTED="amd64 arm64 armhf i386"
get_github_releases "getnf/getnf" "latest"
if [ "${ACTION}" != "prettylist" ]; then
    URL=$(grep -m 1 "browser_download_url.*_all\.deb\"" "${CACHE_FILE}" | cut -d '"' -f 4)
    VERSION_PUBLISHED=$(cut -d '/' -f 8 <<< "${URL//v/}")
fi
PRETTY_NAME="getnf"
WEBSITE="https://github.com/getnf/getnf"
SUMMARY="Easily install Nerd Fonts from the terminal."
