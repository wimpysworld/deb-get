DEFVER=1
ARCHS_SUPPORTED="amd64 arm64"
get_github_releases "Vencord/Vesktop" "latest"
if [ "${ACTION}" != "prettylist" ]; then
    URL=$(grep -m 1 "browser_download_url.*${HOST_ARCH}\.deb\"" "${CACHE_FILE}" | cut -d '"' -f 4)
    VERSION_PUBLISHED=$(cut -d '/' -f 8 <<< "${URL//v/}")
fi
PRETTY_NAME="Vesktop"
WEBSITE="https://vesktop.dev/"
SUMMARY="Vesktop is a customizable and privacy friendly Discord desktop app!"
