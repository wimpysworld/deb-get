DEFVER=1
ARCHS_SUPPORTED="amd64 arm64 armhf i386 ppc64el riscv64 s390x"
get_github_releases "snoack/mypass" "latest"
if [ "${ACTION}" != "prettylist" ]; then
    URL="$(grep -m 1 "browser_download_url.*\.deb\"" "${CACHE_FILE}" | cut -d'"' -f4)"
    VERSION_PUBLISHED=$(cut -d '/' -f 8 <<< "${URL//v/}")
fi
PRETTY_NAME="mypass"
WEBSITE="https://github.com/snoack/mypass"
SUMMARY="A secure password manager that can be used conveniently from the command line."
